{
  "include": [
    "**/*.vue",
    "**/*.tsx",
    "**/*.js",
    "*.js",
    "*.ts",
    "**/*",
    "./*",
    "*.*",
    "src/*",
    "tsconfig.json",
    "eslint.config.js"
  ],
  "compilerOptions": {
    "composite": true,
    "module": "nodenext",
    "strictNullChecks": true,
    "moduleResolution": "nodenext",
    "allowJs": true,
    "checkJs": true,
    "jsx": "react",
    "target": "esnext"
  }
}
