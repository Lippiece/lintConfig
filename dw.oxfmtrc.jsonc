{
  "$schema": "/home/lippiece/node_modules/oxfmt/configuration_schema.json",
  "singleAttributePerLine": true,
  "sortTailwindcss": true,
  "sortImports": true,
  "semi": false,
  "tabWidth": 2,
  "singleQuote": true,
  "printWidth": 80,
  "trailingComma": "none",
  "arrowParens": "always",
  "bracketSameLine": false,
  "quoteProps": "preserve"
}
